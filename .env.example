# Set this to your dev machine's LAN IP (Android emulator uses 10.0.2.2, physical device needs your IP)
EXPO_PUBLIC_API_URL=http://192.168.x.x:8000/api/v1

# Google Sign-In: OAuth client IDs from Google Cloud Console (Credentials → OAuth client ID).
# Web client ID is required even for native flows (used as the token audience on Android/iOS
# when there's no dedicated native client). Android additionally needs your release/debug
# SHA-1 fingerprint registered against the Android client ID; iOS needs the bundle ID
# (com.delniapp.mobile) registered against the iOS client ID.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
